import { createFileRoute, redirect } from "@tanstack/react-router";
import { {{pascalCase name}}Page } from "@/features/{{name}}";

/**
 * Authenticated route for {{name}}.
 *
 * This is a thin wrapper -- all UI logic lives in the feature component.
 * The beforeLoad guard redirects unauthenticated users to /login.
 */
export const Route = createFileRoute("/_app/_auth/{{name}}")({
  beforeLoad: async ({ context }) => {
    if (!context.user) {
      throw redirect({ to: "/login" });
    }
  },
  component: {{pascalCase name}}Page,
});
